<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>PowerMeter connects to your cycling power sensor via Bluetooth to display real-time power, cadence, and resistance data.</string>
	<key>NSBluetoothPeripheralUsageDescription</key>
	<string>PowerMeter connects to your cycling power sensor via Bluetooth.</string>
	<key>NSHealthShareUsageDescription</key>
	<string>PowerMeter reads your heart rate from Apple Watch to display it during your ride.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>PowerMeter saves your cycling workouts including power, cadence, and heart rate data to Apple Health.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>bluetooth-central</string>
	</array>
</dict>
</plist>
